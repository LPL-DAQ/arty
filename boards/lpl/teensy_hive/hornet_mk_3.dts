/*
Hornet Mk. 3 board.
 */

/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/*
TODO:
- LoRa radio
- Remove ADC1
- PWM for servos, propellers, etc
*/

/ {
    model = "Hornet Mk. 3";

    chosen {
        zephyr,console = &cdc_acm_uart0;
    };
};

// VN-300 IMU
&lpuart1 {
    status = "okay";
    current-speed = <115200>;
};

// TF-02 Pro LiDARs
&lpuart2 {
    status = "okay";
    current-speed = <115200>;
};

&lpuart8 {
    status = "okay";
    current-speed = <115200>;
};

// JAVAD TR-2S GNSS
&lpuart3 {
    status = "okay";
    current-speed = <115200>; // Is this right?
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [ 67 67 67 67 67 67  ];
};

&pinctrl {
    lpi2c1_default: pinmux_lpi2c1 {
        pinmux = <&iomuxc_gpio_ad_b1_00_lpi2c1_scl>,
                 <&iomuxc_gpio_ad_b1_01_lpi2c1_sda>;
        bias-pull-up;
        drive-open-drain;
    };

    lpi2c3_default: pinmux_lpi2c3 {
        pinmux = <&iomuxc_gpio_ad_b1_06_lpi2c3_sda>,
                 <&iomuxc_gpio_ad_b1_07_lpi2c3_scl>;
        bias-pull-up;
        drive-open-drain;
    };
};

&lpi2c1 {
    pinctrl-0 = <&lpi2c1_default>;
    pinctrl-names = "default";
    clock-frequency = <100000>;
    status = "okay";

    mcp23017_u4: gpio@20 {
        compatible = "microchip,mcp23017";
        reg = <0x20>;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };
};

&lpi2c3 {
    pinctrl-0 = <&lpi2c3_default>;
    pinctrl-names = "default";
    clock-frequency = <100000>;
    status = "okay";

    mcp23017_u6: gpio@20 {
        compatible = "microchip,mcp23017";
        reg = <0x20>;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };
};
