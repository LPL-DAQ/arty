/*
Hornet Mk. 3 board.

PWM pin mapping (from Teensy 4.1 reference):
  servo_l      AD_B0_09   -> FlexPWM2.3 A
  servo_r      Pin 3  -> EMC_05    -> FlexPWM4.2 B
  motor_beta1  Pin 6  -> B0_10     -> FlexPWM2.2 A
  motor_beta2  Pin 22 -> AD_B1_08  -> FlexPWM4.0 A
  motor_beta3  Pin 23 -> AD_B1_09  -> FlexPWM4.1 A
  motor_beta4  Pin 28 -> EMC_32    -> FlexPWM3.1 B
  motor_cr     Pin 29 -> EMC_31    -> FlexPWM3.1 A
*/

/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/pwm/pwm.h>

#define ANALOG_SENSORS_ADC_RESOLUTION 12
#define ANALOG_SENSORS_ADC_OVERSAMPLING 5

/ {
    model = "Hornet Mk. 3";

    aliases {
        analog-sensors-adc = &adc1;
        fuel-valve-stepper-pulse-counter = &pit0_channel0;
        lox-valve-stepper-pulse-counter = &pit0_channel1;
    };

    zephyr,user {
        fuel-valve-stepper-pul-gpios = <&gpio2 2 GPIO_ACTIVE_HIGH>; // Pin 11
        fuel-valve-stepper-dir-gpios = <&gpio2 1 GPIO_ACTIVE_HIGH>; // Pin 12
        fuel-valve-stepper-ena-gpios = <&gpio2 0 GPIO_ACTIVE_HIGH>; // Pin 10
        fuel-valve-encoder-a-gpios = <&gpio4 8 GPIO_ACTIVE_HIGH>; // Pin 5
        fuel-valve-encoder-b-gpios = <&gpio4 6 GPIO_ACTIVE_HIGH>; // Pin 4

        lox-valve-stepper-pul-gpios = <&gpio2 16 GPIO_ACTIVE_HIGH>; // Pin 8
        lox-valve-stepper-dir-gpios = <&gpio2 11 GPIO_ACTIVE_HIGH>; // Pin 9
        lox-valve-stepper-ena-gpios = <&gpio2 17 GPIO_ACTIVE_HIGH>; // Pin 7
        lox-valve-encoder-a-gpios = <&gpio4 4 GPIO_ACTIVE_HIGH>; // Pin 2
        lox-valve-encoder-b-gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>; // Pin 1

        // ADC channels used by AnalogSensors.
        analog-sensor-max-adc-channels = <16>;
        io-channels = <&adc1 5>, <&adc1 6>, <&adc1 8>, <&adc1 9>, <&adc1 10>, <&adc1 11>, <&adc1 12>, <&adc1 15>;
        analog-sensor-adcs = <&adc1>;
         // analog-sensor-channels = <&adc1 5>, <&adc1 6>, <&adc1 8>, <&adc1 9>, <&adc1 10>, <&adc1 11>, <&adc1 12>, <&adc1 15>;
        analog-sensor-adc-oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
        analog-sensor-adc-resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;

        /* PWM channels — accessed via PWM_DT_SPEC_GET_BY_NAME(DT_PATH(zephyr_user), <name>) */
        pwms = <&flexpwm2_pwm3 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* servo_l     Pin 2  AD_B0_09  FlexPWM2.3 A */
               <&flexpwm4_pwm2 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* servo_r     Pin 3  EMC_05    FlexPWM4.2 B */
               <&flexpwm2_pwm2 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta1 Pin 6  B0_10     FlexPWM2.2 A */
               <&flexpwm4_pwm0 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta2 Pin 22 AD_B1_08  FlexPWM4.0 A */
               <&flexpwm4_pwm1 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta3 Pin 23 AD_B1_09  FlexPWM4.1 A */
               <&flexpwm3_pwm1 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta4 Pin 28 EMC_32    FlexPWM3.1 B */
               <&flexpwm3_pwm1 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>;  /* motor_cr    Pin 29 EMC_31    FlexPWM3.1 A */

        pwm-names = "servo_l", "servo_r",
                    "motor_beta1", "motor_beta2", "motor_beta3", "motor_beta4",
                    "motor_cr";
    };

    chosen {
        zephyr,console = &cdc_acm_uart0;
        // zephyr,console = &lpuart7;
    };

    example_sensor: example-sensor {
        compatible = "zephyr,example-sensor";
        input-gpios = <&gpio6 18 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
    };

    blink_led: blink-led {
        compatible = "blink-gpio-led";
        led-gpios = <&gpio2 3 GPIO_ACTIVE_HIGH>;
        blink-period-ms = <1000>;
    };
};

&lpuart7 {
	status = "okay";
	current-speed = <115200>;
};

// Docs: https://docs.zephyrproject.org/latest/build/dts/api/bindings/pinctrl/nxp%2Cmcux-rt-pinctrl.html
&pinctrl {
    pinmux_adc1: pinmux_adc1 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b1_04_gpio1_io20>,
                     <&iomuxc_gpio_ad_b1_05_gpio1_io21>,
                     <&iomuxc_gpio_ad_b1_03_gpio1_io19>,
                     <&iomuxc_gpio_ad_b1_07_gpio1_io23>,
                     <&iomuxc_gpio_ad_b1_06_gpio1_io22>,
                     <&iomuxc_gpio_ad_b1_00_gpio1_io16>,
                     <&iomuxc_gpio_ad_b1_01_gpio1_io17>,
                     <&iomuxc_gpio_ad_b1_10_gpio1_io26>;
                     bias-disable; // These should be pulled down by voltage divider
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* AD_B0_09 -> FlexPWM2_PWMA3 (servo_l) */
    pinmux_flexpwm2_pwm3: pinmux_flexpwm2_pwm3 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b0_09_flexpwm2_pwma3>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* Pin 3: EMC_05 -> FlexPWM4_PWMB2 (servo_r) */
    pinmux_flexpwm4_pwm2: pinmux_flexpwm4_pwm2 {
        group0 {
            pinmux = <&iomuxc_gpio_emc_05_flexpwm4_pwmb2>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* Pin 6: B0_10 -> FlexPWM2_PWMA2 (motor_beta1) */
    pinmux_flexpwm2_pwm2: pinmux_flexpwm2_pwm2 {
        group0 {
            pinmux = <&iomuxc_gpio_b0_10_flexpwm2_pwma2>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* Pin 22: AD_B1_08 -> FlexPWM4_PWMA0 (motor_beta2) */
    pinmux_flexpwm4_pwm0: pinmux_flexpwm4_pwm0 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b1_08_flexpwm4_pwma0>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* Pin 23: AD_B1_09 -> FlexPWM4_PWMA1 (motor_beta3) */
    pinmux_flexpwm4_pwm1: pinmux_flexpwm4_pwm1 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b1_09_flexpwm4_pwma1>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };

    /* Pin 28: EMC_32 -> FlexPWM3_PWMB1 (motor_beta4)
       Pin 29: EMC_31 -> FlexPWM3_PWMA1 (motor_cr)
       Both on FlexPWM3 submodule 1, so combine in one pinctrl group */
    pinmux_flexpwm3_pwm1: pinmux_flexpwm3_pwm1 {
        group0 {
            pinmux = <&iomuxc_gpio_emc_32_flexpwm3_pwmb1>,
                     <&iomuxc_gpio_emc_31_flexpwm3_pwma1>;
            bias-disable;
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };
};

// Docs: https://docs.zephyrproject.org/latest/build/dts/api/bindings/adc/nxp%2Cmcux-12b1msps-sar.
&adc1 {
    // She's broken, he's...
    status = "okay";
    pinctrl-0 = <&pinmux_adc1>;
    pinctrl-names = "default";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@5 {
        reg = <0x5>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@6 {
        reg = <0x6>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@8 {
        reg = <0x8>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@9 {
        reg = <0x9>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@a {
        reg = <0xa>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@b {
        reg = <0xb>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@c {
        reg = <0xc>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@f {
        reg = <0xf>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };
};

/* ------------------------------------------------------------------ */
/* FlexPWM submodule enables with pinctrl — unchanged                 */
/* ------------------------------------------------------------------ */

/* servo_l — AD_B0_09 (FlexPWM2 submodule 3, A) */
&flexpwm2_pwm3 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm2_pwm3>;
    status = "okay";
};

/* motor_beta1 — Pin 6 (FlexPWM2 submodule 2, A) */
&flexpwm2_pwm2 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm2_pwm2>;
    status = "okay";
};

/* motor_beta4 (Pin 28, B) + motor_cr (Pin 29, A) — FlexPWM3 submodule 1 */
&flexpwm3_pwm1 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm3_pwm1>;
    status = "okay";
};

/* motor_beta2 — Pin 22 (FlexPWM4 submodule 0, A) */
&flexpwm4_pwm0 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm4_pwm0>;
    status = "okay";
};

/* motor_beta3 — Pin 23 (FlexPWM4 submodule 1, A) */
&flexpwm4_pwm1 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm4_pwm1>;
    status = "okay";
};

/* servo_r — Pin 3 (FlexPWM4 submodule 2, B) */
&flexpwm4_pwm2 {
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_flexpwm4_pwm2>;
    status = "okay";
};

// Timer for stepper pulses.
// Docs: https://docs.zephyrproject.org/latest/build/dts/api/bindings/counter/nxp%2Cpit.html
// Teensyduino equivalent: https://sourcegraph.com/github.com/PaulStoffregen/cores/-/blob/teensy4/IntervalTimer.cpp

&pit0 {
    status = "okay";
};

&pit0_channel0 {
    status = "okay";
};

&pit0_channel1 {
    status = "okay";
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&lpuart6 {
    status = "disabled";
};

&lpuart4 {
    status = "okay";
    current-speed = <115200>;
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [67 67 67 67 67 67];
};
