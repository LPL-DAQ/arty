/*
Hornet Mk. 3 board.
 */


/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/pwm/pwm.h>

#define ANALOG_SENSORS_ADC_RESOLUTION 12
#define ANALOG_SENSORS_ADC_OVERSAMPLING 5

/*
TODO:
- LoRa radio
- Remove ADC1
- PWM for servos, propellers, etc
*/

/*
TODO:
- LoRa radio
- Remove ADC1
- PWM for servos, propellers, etc
*/

/ {
    model = "Hornet Mk. 3";

    aliases {
        // VN-300 IMU
        imu-uart = &lpuart1; // TX: Pin 1, RX: Pin 0

        // TF02-Pro LiDARs
        lidar-1-uart = &lpuart2; // TX: Pin 8, RX: Pin 7
        lidar-2-uart = &lpuart8; // TX: Pin 35, RX: Pin 34

        // JAVAD TR-2S GNSS
        gnss-uart = &lpuart3; // TX: Pin 14, RX: Pin 13

        // RFM95W LoRa tranceiver
        lora-tranceiver = &sx1276;
    };

    zephyr,user {
        // ADC channels used by AnalogSensors.
        analog-sensor-max-adc-channels = <16>;
        io-channels = <&adc2 3>,
                      <&adc1 5>,
                      <&adc1 6>,
                      <&adc1 8>,
                      <&adc1 9>,
                      <&adc1 10>,
                      <&adc1 11>,
                      <&adc1 12>,
                      <&adc1 15>;
        analog-sensor-adcs = <&adc1 &adc2>;
        analog-sensor-adc-oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
        analog-sensor-adc-resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;


        /* PWM channels — accessed via PWM_DT_SPEC_GET_BY_NAME(DT_PATH(zephyr_user), <name>) */
        pwms = <&flexpwm2_pwm3 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* servo_l     Pin 2  AD_B0_09  FlexPWM2.3 A */
               <&flexpwm4_pwm2 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* servo_r     Pin 3  EMC_05    FlexPWM4.2 B */
               <&flexpwm2_pwm2 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>,   /* motor_beta1 Pin 9  B0_11     FlexPWM2.2 B */
               <&flexpwm4_pwm0 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta2 Pin 22 AD_B1_08  FlexPWM4.0 A */
               <&flexpwm4_pwm1 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta3 Pin 23 AD_B1_09  FlexPWM4.1 A */
               <&flexpwm3_pwm1 1 PWM_USEC(20000) PWM_POLARITY_NORMAL>,  /* motor_beta4 Pin 28 EMC_32    FlexPWM3.1 B */
               <&flexpwm3_pwm1 0 PWM_USEC(20000) PWM_POLARITY_NORMAL>;  /* motor_cr    Pin 29 EMC_31    FlexPWM3.1 A */

        pwm-names = "servo_l", "servo_r",
                    "motor_beta1", "motor_beta2", "motor_beta3", "motor_beta4",
                    "motor_cr";
    };

    chosen {
        zephyr,console = &cdc_acm_uart0;
    };
};

// VN-300 IMU
&lpuart1 {
    status = "okay";
    current-speed = <115200>;
};

// TF-02 Pro LiDARs
&lpuart2 {
    status = "okay";
    current-speed = <115200>;
};

&lpuart8 {
    status = "okay";
    current-speed = <115200>;
};

// JAVAD TR-2S GNSS
&lpuart3 {
    status = "okay";
    current-speed = <115200>; // Is this right?
};

// TODO: RFM95W RF CHIP, validate this? Duped on hornet/vehicle boards.
&lpspi4 {
    status = "okay";

    // TODO: Are the miso/mosi correct? this driver has a mio/sdo and I'm pretty sure there's an option to set which is miso/mosi.

    // Hardware CS0: Pin 10
    // MOSI: Pin 11
    // MISO: Pin 12
    // SCK: Pin 13

    // Is this right?
    // RFM95W: https: //www.adafruit.com/product/3072
    sx1276: sx1276@0 {
        compatible = "semtech,sx1276";
        reg = <0x0>;
        reset-gpios = <&gpio4 4 GPIO_ACTIVE_HIGH>; // Pin 4
        dio-gpios = <&gpio2 10 GPIO_ACTIVE_HIGH>; // Pin 6
        spi-max-frequency = <DT_FREQ_M(67)>; // THIS IS 100% WRONG!!!! FIX ME!!!!!
    };
};

// Docs: https: //docs.zephyrproject.org/latest/build/dts/api/bindings/pinctrl/nxp%2Cmcux-rt-pinctrl.html
&pinctrl {
    pinmux_adc1: pinmux_adc1 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b1_04_gpio1_io20>,
                     <&iomuxc_gpio_ad_b1_05_gpio1_io21>,
                     <&iomuxc_gpio_ad_b1_03_gpio1_io19>,
                     <&iomuxc_gpio_ad_b1_07_gpio1_io23>,
                     <&iomuxc_gpio_ad_b1_06_gpio1_io22>,
                     <&iomuxc_gpio_ad_b1_00_gpio1_io16>,
                     <&iomuxc_gpio_ad_b1_01_gpio1_io17>,
                     <&iomuxc_gpio_ad_b1_10_gpio1_io26>;
            bias-disable; // These should be pulled down by voltage divider
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };
    pinmux_adc2: pinmux_adc2 {
        group0 {
            pinmux = <&iomuxc_gpio_ad_b1_14_gpio1_io30>; // A12, pin 26
            bias-disable; // These should be pulled down by voltage divider
            drive-strength = "r0-6";
            slew-rate = "slow";
            nxp,speed = "100-mhz";
        };
    };
};

// Docs: https: //docs.zephyrproject.org/latest/build/dts/api/bindings/adc/nxp%2Cmcux-12b1msps-sar.
&adc1 {
    // She's broken, he's...
    status = "okay";
    pinctrl-0 = <&pinmux_adc1>;
    pinctrl-names = "default";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@5 {
        reg = <0x5>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@6 {
        reg = <0x6>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@8 {
        reg = <0x8>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@9 {
        reg = <0x9>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@a {
        reg = <0xa>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@b {
        reg = <0xb>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@c {
        reg = <0xc>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };

    channel@f {
        reg = <0xf>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };
};

// ADC for battery sense
&adc2 {
    status = "okay";
    pinctrl-0 = <&pinmux_adc2>;
    pinctrl-names = "default";
    #address-cells = <1>;
    #size-cells = <0>;

    channel@3 {
        reg = <0x3>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        zephyr,oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [ 67 67 67 67 67 67  ];
};
