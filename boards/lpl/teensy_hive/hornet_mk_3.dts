/*
Hornet Mk. 3 board.
 */

/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
    model = "Hornet Mk. 3";

    chosen {
        zephyr,console = &cdc_acm_uart0;
    };

    zephyr,user {
        io-channels =
            <&ads7953_1 0>,
            <&ads7953_1 1>,
            <&ads7953_2 0>,
            <&ads7953_2 1>;
        io-channel-names =
            "bank1_ain0",
            "bank1_ain1",
            "bank2_ain0",
            "bank2_ain1";
    };
};

// VN-300 IMU
&lpuart1 {
    status = "okay";
    current-speed = <115200>;
};

// TF-02 Pro LiDARs
&lpuart2 {
    status = "okay";
    current-speed = <115200>;
};

&lpuart8 {
    status = "okay";
    current-speed = <115200>;
};

// JAVAD TR-2S GNSS
&lpuart3 {
    status = "okay";
    current-speed = <115200>;
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [ 67 67 67 67 67 67 ];
};

&lpspi4 {
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_lpspi4>;

    cs-gpios = <&gpio1 4 GPIO_ACTIVE_LOW>,   /* U7 / Bank 1 */
               <&gpio1 5 GPIO_ACTIVE_LOW>;   /* U8 / Bank 2 */

    ads7953_1: adc@0 {
        compatible = "ti,ads7953";
        reg = <0>;
        spi-max-frequency = <5000000>;
        #io-channel-cells = <1>;
        ti,range = <1>;
        status = "okay";

        #address-cells = <1>;
        #size-cells = <0>;

        channel@0 {
            reg = <0>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <12>;
        };

        channel@1 {
            reg = <1>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <12>;
        };
    };

    ads7953_2: adc@1 {
        compatible = "ti,ads7953";
        reg = <1>;
        spi-max-frequency = <5000000>;
        #io-channel-cells = <1>;
        ti,range = <1>;
        status = "okay";

        #address-cells = <1>;
        #size-cells = <0>;

        channel@0 {
            reg = <0>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <12>;
        };

        channel@1 {
            reg = <1>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <12>;
        };
    };
};
