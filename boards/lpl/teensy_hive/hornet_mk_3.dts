/*
Hornet Mk. 3 board.
 */

/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/*
TODO:
- LoRa radio
- Remove ADC1
- PWM for servos, propellers, etc
*/

/ {
    model = "Hornet Mk. 3";

    chosen {
        zephyr,console = &cdc_acm_uart0;
    };

    aliases {
        mcp0 = &mcp0;
    };

    mcp0: mcp0 {
        gpios = <&mcp23017 0 GPIO_ACTIVE_HIGH>;
    };
};

// VN-300 IMU
&lpuart1 {
    status = "okay";
    current-speed = <115200>;
};

// TF-02 Pro LiDARs
&lpuart2 {
    status = "okay";
    current-speed = <115200>;
};

&lpuart8 {
    status = "okay";
    current-speed = <115200>;
};

// JAVAD TR-2S GNSS
&lpuart3 {
    status = "okay";
    current-speed = <115200>; // Is this right?
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [ 67 67 67 67 67 67  ];
};

&lpi2c3 {
    status = "okay";

    mcp23017: gpio@20 {
        compatible = "microchip,mcp23017";
        reg = <0x20>;
        gpio-controller;
        #gpio-cells = <2>;
        status = "okay";
    };
};
