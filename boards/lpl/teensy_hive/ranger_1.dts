/*
Ranger 1 board.
 */

/dts-v1/;

#include <../boards/pjrc/teensy4/teensy41.dts>
#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

#define ANALOG_SENSORS_ADC_RESOLUTION 12
// ADS7953 does not support oversampling; 2^0 = 1 samples.
#define ANALOG_SENSORS_ADC_OVERSAMPLING 0

/*
TODO:
- LoRa radio
- GPIO expanders
- TVC CANBUS
*/

/ {
    model = "Ranger 1";

    aliases {
        // VN-300 IMU
        imu-uart = &lpuart1; // TX: Pin 1, RX: Pin 0

        // TF02-Pro LiDARs
        lidar-1-uart = &lpuart2; // TX: Pin 8, RX: Pin 7
        lidar-2-uart = &lpuart8; // TX: Pin 35, RX: Pin 34

        // JAVAD TR-2S GNSS
        gnss-uart = &lpuart3; // TX: Pin 14, RX: Pin 13

        // RFM95W LoRa tranceiver
        // lora-tranceiver = &sx1276;

        // Throttle motor driver hardware timers, controls PUL/DIR signals.
        fuel-valve-stepper-pulse-counter = &pit0_channel0;
        lox-valve-stepper-pulse-counter = &pit0_channel1;
    };

    zephyr,user {
        // Throttle motor drivers
        fuel-valve-stepper-pul-gpios = <&gpio2 2 GPIO_ACTIVE_HIGH>; // Pin 11
        fuel-valve-stepper-dir-gpios = <&gpio2 1 GPIO_ACTIVE_HIGH>; // Pin 12
        fuel-valve-stepper-ena-gpios = <&gpio2 0 GPIO_ACTIVE_HIGH>; // Pin 10
        fuel-valve-encoder-a-gpios = <&gpio4 8 GPIO_ACTIVE_HIGH>; // Pin 5
        fuel-valve-encoder-b-gpios = <&gpio4 6 GPIO_ACTIVE_HIGH>; // Pin 4

        lox-valve-stepper-pul-gpios = <&gpio2 16 GPIO_ACTIVE_HIGH>; // Pin 8
        lox-valve-stepper-dir-gpios = <&gpio2 11 GPIO_ACTIVE_HIGH>; // Pin 9
        lox-valve-stepper-ena-gpios = <&gpio2 17 GPIO_ACTIVE_HIGH>; // Pin 7
        lox-valve-encoder-a-gpios = <&gpio4 4 GPIO_ACTIVE_HIGH>; // Pin 2
        lox-valve-encoder-b-gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>; // Pin 1

        // ADC channels used by AnalogSensors.
        analog-sensor-max-adc-channels = <16>;
        io-channels =
            <&ads7953_1 0>,
            <&ads7953_1 1>,
            <&ads7953_1 2>,
            <&ads7953_1 3>,
            <&ads7953_1 4>,
            <&ads7953_1 5>,
            <&ads7953_1 6>,
            <&ads7953_1 7>,
            <&ads7953_1 8>,
            <&ads7953_1 9>,
            <&ads7953_1 10>,
            <&ads7953_1 11>,
            <&ads7953_1 12>,
            <&ads7953_1 13>,
            <&ads7953_1 14>,
            <&ads7953_1 15>;
            // <&ads7953_2 0>,
            // <&ads7953_2 1>,
            // <&ads7953_2 2>,
            // <&ads7953_2 3>,
            // <&ads7953_2 4>,
            // <&ads7953_2 5>,
            // <&ads7953_2 6>,
            // <&ads7953_2 7>,
            // <&ads7953_2 8>,
            // <&ads7953_2 9>,
            // <&ads7953_2 10>,
            // <&ads7953_2 11>,
            // <&ads7953_2 12>,
            // <&ads7953_2 13>,
            // <&ads7953_2 14>,
            // <&ads7953_2 15>;
        // io-channel-names = "adc1_0", "adc1_1", "adc1_2", "adc1_3", "adc1_4", "adc1_5", "adc1_6", "adc1_7", "adc1_8", "adc1_9", "adc1_10", "adc1_11", "adc1_12", "adc1_13", "adc1_14", "adc1_15",
        // "adc2_0", "adc2_1", "adc2_2", "adc2_3", "adc2_4", "adc2_5", "adc2_6", "adc2_7", "adc2_8", "adc2_9", "adc2_10", "adc2_11", "adc2_12", "adc2_13", "adc2_14", "adc2_15";
        // analog-sensor-adcs = <&ads7953_1 &ads7953_2>;
        analog-sensor-adcs = <&ads7953_1>;
        analog-sensor-adc-oversampling = <ANALOG_SENSORS_ADC_OVERSAMPLING>;
        analog-sensor-adc-resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;

        // GPIOs connected to valves. Valve channel numbers are indexed by their position in this list.
        valve-gpios = <&gpio2 10 GPIO_ACTIVE_HIGH>, <&gpio2 17 GPIO_ACTIVE_HIGH>, <&gpio2 16 GPIO_ACTIVE_HIGH>;
    };

    chosen {
        zephyr,console = &cdc_acm_uart0;
    };
};

// VN-300 IMU
&lpuart1 {
    status = "okay";
    current-speed = <115200>;
};

// TF-02 Pro LiDARs
&lpuart2 {
    status = "okay";
    current-speed = <115200>;
};

&lpuart8 {
    status = "okay";
    current-speed = <115200>;
};

// JAVAD TR-2S GNSS
&lpuart3 {
    status = "okay";
    current-speed = <115200>; // Is this right?
};

// // TODO: RFM95W RF CHIP, validate this? Duped on hornet/vehicle boards.
// &lpspi4 {
//     status = "okay";

//     // TODO: Are the miso/mosi correct? this driver has a mio/sdo and I'm pretty sure there's an option to set which is miso/mosi.

//     // Hardware CS0: Pin 10
//     // MOSI: Pin 11
//     // MISO: Pin 12
//     // SCK: Pin 13

//     // Is this right?
//     // RFM95W: https: //www.adafruit.com/product/3072
//     sx1276: sx1276@0 {
//         compatible = "semtech,sx1276";
//         reg = <0x0>;
//         reset-gpios = <&gpio4 4 GPIO_ACTIVE_HIGH>; // Pin 4
//         dio-gpios = <&gpio2 10 GPIO_ACTIVE_HIGH>; // Pin 6
//         spi-max-frequency = <DT_FREQ_M(67)>; // THIS IS 100% WRONG!!!! FIX ME!!!!!
//     };
// };



&lpspi4 {
    status = "okay";
    pinctrl-names = "default";
    pinctrl-0 = <&pinmux_lpspi4>;

    cs-gpios = <&gpio1 4 GPIO_ACTIVE_LOW>,   /* U7 / Bank 1 */
               <&gpio1 5 GPIO_ACTIVE_LOW>;   /* U8 / Bank 2 */

    ads7953_1: adc@0 {
        status = "okay";
        compatible = "ti,ads7953";
        reg = <0>;
        spi-max-frequency = <5000000>;
        #io-channel-cells = <1>;
        ti,range = <2>; // 2x V_REF of 2.5V

        #address-cells = <1>;
        #size-cells = <0>;

        channel@0 {
            reg = <0>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@1 {
            reg = <1>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@2 {
            reg = <2>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@3 {
            reg = <3>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@4 {
            reg = <4>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@5 {
            reg = <5>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@6 {
            reg = <6>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@7 {
            reg = <7>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@8 {
            reg = <8>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@9 {
            reg = <9>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@a {
            reg = <10>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@b {
            reg = <11>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@c {
            reg = <12>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@d {
            reg = <13>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@e {
            reg = <14>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@f {
            reg = <15>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };
    };

    ads7953_2: adc@1 {
        status = "okay";
        compatible = "ti,ads7953";
        reg = <1>;
        spi-max-frequency = <5000000>;
        #io-channel-cells = <1>;
        ti,range = <2>;

        #address-cells = <1>;
        #size-cells = <0>;

        channel@0 {
            reg = <0>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@1 {
            reg = <1>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@2 {
            reg = <2>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@3 {
            reg = <3>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@4 {
            reg = <4>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@5 {
            reg = <5>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@6 {
            reg = <6>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@7 {
            reg = <7>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@8 {
            reg = <8>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@9 {
            reg = <9>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@a {
            reg = <10>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@b {
            reg = <11>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@c {
            reg = <12>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@d {
            reg = <13>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@e {
            reg = <14>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };

        channel@f {
            reg = <15>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_VDD_1";
            zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
            zephyr,resolution = <ANALOG_SENSORS_ADC_RESOLUTION>;
        };
    };
};

// Timer for stepper pulses.
// Docs: https: //docs.zephyrproject.org/latest/build/dts/api/bindings/counter/nxp%2Cpit.html
// Teensyduino equivalent: https: //sourcegraph.com/github.com/PaulStoffregen/cores/-/blob/teensy4/IntervalTimer.cpp
&pit0 {
    status = "okay";
};

&pit0_channel0 {
    status = "okay";
};

&pit0_channel1 {
    status = "okay";
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
        label = "CDC_ACM_0";
    };
};

&enet_mac {
    /delete-property/ nxp,unique-mac;
    local-mac-address = [ 67 67 67 67 67 67  ];
};
